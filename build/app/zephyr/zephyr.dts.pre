# 4 "/workspace/application/boards/st/gartennode/gartennode.dts" 2

/ {
 model = "Gartennode";
 compatible = "st,stm32l431kc";

 chosen {
  zephyr,console = &usart1;
  zephyr,shell-uart = &usart1;
  zephyr,sram = &sram0;
  zephyr,flash = &flash0;
  zephyr,code-partition = &slot0_partition;
  zephyr,canbus = &can1;
  zephyr,settings-partition = &storage_partition;
 };

 leds: leds {
  compatible = "gpio-leds";
  green_led: led_0 {
   gpios = <&gpioc 15 (0 << 0)>;
   label = "User LD1";
  };
 };

 aliases {
  led0 = &green_led;
 };
};

&wwdg {
 status = "disabled";
};

&iwdg {
 status = "okay";
};

&clk_lsi {
 status = "okay";
};

&clk_hsi {
 status = "okay";
};

&pll {
 div-m = <1>;
 mul-n = <20>;
 div-p = <7>;
 div-q = <2>;
 div-r = <4>;
 clocks = <&clk_hsi>;
 status = "okay";
};

&rcc {
 clocks = <&pll>;
 clock-frequency = <(((80) * 1000) * 1000)>;
 ahb-prescaler = <1>;
 apb1-prescaler = <1>;
 apb2-prescaler = <1>;
};

&usart1 {
 pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
 pinctrl-names = "default";
 current-speed = <115200>;
 status = "okay";
};

&spi1 {
 pinctrl-0 = <&spi1_nss_pa15 &spi1_sck_pb3
       &spi1_miso_pb4 &spi1_mosi_pb5>;
 pinctrl-names = "default";
 status = "okay";
 w25q128jv: w25q128jv@0 {
  compatible ="jedec,spi-nor";
  size = <0x8000000>;
  reg = <0>;
  spi-max-frequency = <20000000>;
  hold-gpios = < &gpioa 8 (1 << 0) >;
  status = "okay";
  jedec-id = [ef 40 18];

  partitions {
   compatible = "fixed-partitions";
   #address-cells = <1>;
   #size-cells = <1>;

   slot1_partition: partition@0 {
    label = "image-1";
    reg = <0x00000000 ((192) * 1024)>;
   };
   scratch_partition: partition@30000 {
    label = "image-scratch";
    reg = <0x00030000 ((192) * 1024)>;
   };
   storage_partition: partition@60000 {
    label = "storage";
    reg = <0x00060000 ((32) * 1024)>;
   };
  };
 };
};

&i2c1 {
 pinctrl-0 = <&i2c1_scl_pb6 &i2c1_sda_pb7>;
 pinctrl-names = "default";
 clock-frequency = <400000>;
 status = "okay";
};

&can1 {
 pinctrl-0 = <&can1_rx_pa11 &can1_tx_pa12>;
 pinctrl-names = "default";
 status = "okay";
};

&rtc {
 clocks = <&rcc 0x058 0x10000000>,
   <&rcc 0x003 ((((0x90) & 0xFFFFU) << 0U) | (((8) & 0x1FU) << 16U) | ((((9) - (8)) & 0x3U) << 21U) | ((((2)) & 0xFFU) << 24U))>;
 status = "okay";
};

&flash0 {
 partitions {
  compatible = "fixed-partitions";
  #address-cells = <1>;
  #size-cells = <1>;





  boot_partition: partition@0 {
   label = "mcuboot";
   reg = <0x0 ((64) * 1024)>;
   read-only;
  };




  slot0_partition: partition@10000 {
   label = "image-0";
   reg = <0x00010000 ((192) * 1024)>;
  };
 };
};
# 0 "<command-line>" 2
# 1 "/workspace/application/boards/gartennode.overlay" 1






/ {
 zephyr,user {
  io-channels = <&adc1 8>;
 };

 pressure_sw: pressure_sw {
  compatible = "power-switch";

  gpios = <&gpioa 0 ((1 << 5) | (0 << 0))>;
        status = "okay";
 };

 ultrasonic_sw: ultrasonic_sw {
  compatible = "power-switch";

  gpios = <&gpioa 1 ((1 << 5) | (0 << 0))>;
        status = "okay";
 };

 temperature_sw: temperature_sw {
  compatible = "power-switch";

  gpios = <&gpioa 2 ((1 << 5) | (0 << 0))>;
        status = "okay";
 };

 aliases {
  green-led = &green_led;
 };
    us0: HC-SR04 {
        compatible = "hc-sr04";
        trigger-gpios = <&gpioa 4 (0 << 0)>;
        echo-gpios = <&gpioa 5 ((1 << 5) | (0 << 0))>;
        status = "okay";
    };
 w1_0: w1-zephyr-gpio-0 {
  compatible = "zephyr,w1-gpio";
  gpios = <&gpioa 6 ((0 << 0)|((1 << 1) | (1 << 2))|(1 << 4))>;
  status = "okay";

  temp_0: ds18b200 {
   compatible = "maxim,ds18b20";
   family-code = <0x28>;
   resolution = <12>;
   status = "okay";
  };
  temp_1: ds18b201 {
   compatible = "maxim,ds18b20";
   family-code = <0x28>;
   resolution = <12>;
   status = "okay";
  };
 };
};

&adc1 {
 #address-cells = <1>;
 #size-cells = <0>;


 pinctrl-0 = <&adc1_in8_pa3>;
 pinctrl-names = "default";
 st,adc-clock-source = "SYNC";
 st,adc-prescaler = <4>;
 status = "okay";

 channel@8 {
  reg = <8>;
  zephyr,gain = "ADC_GAIN_1";
  zephyr,reference = "ADC_REF_INTERNAL";
  zephyr,acquisition-time = <0>;
  zephyr,resolution = <12>;
 };
};
# 0 "<command-line>" 2
# 1 "/workspace/zephyr/misc/empty_file.c"
